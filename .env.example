# Firebase web config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Firebase admin
FIREBASE_ADMIN_SDK_KEY={"type":"service_account"}
FIREBASE_SERVICE_ACCOUNT_JSON=

# API runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001
API_TIMEOUT_MS=30000
PORT=8000
LOG_LEVEL=info
NODE_ENV=development
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_SITE_URL=https://sierrablu.luxury

# AI services
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_AI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
OPENCLAW_API_KEY=your_openclaw_api_key
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_TOKEN=your_openclaw_token

# Observability
NEXT_PUBLIC_ENABLE_TELEMETRY=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.arize.com/v1/traces
ARIZE_API_KEY=your_arize_api_key
ARIZE_SPACE_ID=your_arize_space_id
ARIZE_PROJECT_NAME=sierra-blu-platform
DATADOG_API_KEY=your_datadog_api_key
SENTRY_DSN=your_sentry_dsn

# Property Finder
PROPERTY_FINDER_API_KEY=your_property_finder_api_key
PROPERTY_FINDER_API_GATEWAY=https://gateway.propertyfinder.com/v2
PROPERTY_FINDER_CLIENT_ID=your_property_finder_client_id
PROPERTY_FINDER_CLIENT_SECRET=your_property_finder_client_secret
PROPERTY_FINDER_AUTH_TOKEN=your_property_finder_auth_token
PROPERTY_FINDER_WEBHOOK_SECRET=your_property_finder_webhook_secret
PF_WEBHOOK_SECRET=your_property_finder_webhook_secret
SYNC_API_KEY=your_sync_api_key

# Messaging and bots
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_WEBHOOK_SECRET=your_whatsapp_webhook_secret
WHATSAPP_TOKEN=your_whatsapp_cloud_token
PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WABA_ID=your_whatsapp_business_account_id
APP_SECRET=your_whatsapp_app_secret
VERIFY_TOKEN=your_whatsapp_verify_token

# Security
SBR_SECRET_KEY=your_internal_shared_secret_key
CRON_SECRET=your_cron_secret_key
JWT_SECRET=your_jwt_secret_key
ENCRYPTION_KEY=your_32_character_encryption_key

# Batch and data
BATCH_QUEUE_CONCURRENCY=5
BATCH_TIMEOUT_MS=300000
REDIS_URL=redis://localhost:6379
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Owners-Rent,Owners-Resale,Brokers,Team Units

# Feature flags
NEXT_PUBLIC_ENABLE_AGENTS=true
NEXT_PUBLIC_ENABLE_BATCH_PROCESSING=true
NEXT_PUBLIC_ENABLE_ADMIN_PANEL=true
