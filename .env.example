# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=sk-abc123xyz
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sierra-blu-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sierra-blu-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sierra-blu-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123xyz

# Firebase Admin SDK (Server-side only)
FIREBASE_ADMIN_SDK_KEY='{"type":"service_account","project_id":"...}'

# ============================================================================
# API CONFIGURATION
# ============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001
API_TIMEOUT_MS=30000

# ============================================================================
# AI SERVICES
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-proj-...
OPENCLAW_API_KEY=...
OPENCLAW_BASE_URL=http://localhost:18789/v1

# ============================================================================
# BATCH PROCESSING
# ============================================================================
BATCH_QUEUE_CONCURRENCY=5
BATCH_TIMEOUT_MS=300000
REDIS_URL=redis://localhost:6379

# ============================================================================
# OBSERVABILITY & MONITORING
# ============================================================================
NEXT_PUBLIC_ENABLE_TELEMETRY=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.arize.com/v1/traces
ARIZE_API_KEY=...
ARIZE_SPACE_ID=...
ARIZE_PROJECT_NAME=sierra-blu-platform
DATADOG_API_KEY=...
SENTRY_DSN=...

# ============================================================================
# EXTERNAL INTEGRATIONS
# ============================================================================
PROPERTY_FINDER_API_KEY=...
PROPERTY_FINDER_API_GATEWAY=https://api.property-finder.com
PROPERTY_FINDER_CLIENT_ID=...
PROPERTY_FINDER_CLIENT_SECRET=...
PROPERTY_FINDER_WEBHOOK_SECRET=...

TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

WHATSAPP_API_KEY=...
WHATSAPP_WEBHOOK_SECRET=...

# ============================================================================
# SECURITY
# ============================================================================
SBR_SECRET_KEY=your-secret-key-for-internal-apis
CRON_SECRET=your-secret-key-for-scheduled-jobs
JWT_SECRET=your-jwt-secret-key
ENCRYPTION_KEY=your-encryption-key-32-chars

# ============================================================================
# DEPLOYMENT & ENVIRONMENT
# ============================================================================
NEXT_PUBLIC_SITE_URL=https://sierrablu.luxury
NEXT_PUBLIC_ENVIRONMENT=development
NODE_ENV=development
LOG_LEVEL=info

# Optional: Feature flags
NEXT_PUBLIC_ENABLE_AGENTS=true
NEXT_PUBLIC_ENABLE_BATCH_PROCESSING=true
NEXT_PUBLIC_ENABLE_ADMIN_PANEL=true
