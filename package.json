{
  "name": "sierra-estates-platform",
  "version": "1.0.0",
  "description": "Sierra Estates - Luxury Real Estate Platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo run dev --parallel",
    "dev:web": "cd apps/sierra-estates-realty && npm run dev",
    "dev:admin": "cd apps/sierra-estates-admin-portal && npm run dev",
    "dev:functions": "cd functions && npm run dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo run build",
    "build:web": "cd apps/sierra-estates-realty && npm run build",
    "build:admin": "cd apps/sierra-estates-admin-portal && npm run build",
    "build:functions": "cd functions && npm run build",
    "start": "cd apps/sierra-estates-realty && npm start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules pnpm-lock.yaml",
    "deploy": "firebase deploy --project sierra-estates-prod",
    "deploy:staging": "firebase deploy --project sierra-estates-staging",
    "deploy:preview": "firebase deploy --only hosting:preview",
    "validate-build": "npm run lint && npm run type-check && npm run build",
    "pre-commit": "npm run lint && npm run type-check"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "turbo": "^2.9.16",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "overrides": {
      "undici": "7.16.0"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
